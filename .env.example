# 用途: 起動に必要な環境変数名と安全な記入例を示す。
# 必要な理由: 初学者が必要項目を把握しつつ、実キーをGitへ入れる事故を防ぐため。
# 関連ファイル: app/config.pyが同名変数を読み、config/agents.yml内の${...}へ反映する。
# 実際の秘密値はGit管理外の.env.localまたはSecret Managerへ保存する。
OPENAI_API_KEY=replace-with-a-real-key
OPENAI_MODEL=gpt-5.4-mini
KNOWLEDGE_MCP_URL=http://127.0.0.1:8790/mcp
TICKET_MCP_URL=http://127.0.0.1:8791/mcp
SESSION_SECRET=replace-with-at-least-32-random-characters
MCP_AUTH_SECRET=replace-with-a-different-random-secret
COOKIE_SECURE=false
